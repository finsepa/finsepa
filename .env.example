# Copy to `.env.local` and fill in. For production, set the same keys in Vercel:
# Project → Settings → Environment Variables (Production + Preview), then redeploy.

# Supabase — required for auth and any client using getSupabaseBrowserClient().
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public origin for auth redirects (sign-up confirmation link, OAuth callback). No trailing slash.
# Production (Vercel): https://app.finsepa.com — ensures Supabase redirect_to is https + /auth/callback, not a bad browser origin.
# Local: omit to use http://localhost:3000 from the browser, or set NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_APP_ORIGIN=https://app.finsepa.com

# Supabase service role — server-only (watchlist counts, `/api/auth/signup-with-loops` admin generateLink). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# Auth emails (sign-up confirmation, password reset): use Supabase Dashboard → Authentication → SMTP
# with Loops as the provider (host smtp.loops.so, user "loops", password = Loops API key). See:
# https://loops.so/docs/smtp — credentials live in Supabase, not in these Next.js env vars.
# Enable "Confirm email" under Authentication → Providers → Email so sign-ups must verify.
#
# If Supabase still returns "Error sending confirmation email" or email rate limits, Finsepa falls back to Loops HTTP API (needs service role + LOOPS_API_KEY):
# LOOPS_API_KEY=                    # required for fallback — from https://app.loops.so → Settings → API
# LOOPS_TRANSACTIONAL_ID_SIGNUP=  # optional; defaults to Finsepa sign-up template cm54x9u6103qnqa68w7cg1ls7
# LOOPS_TRANSACTIONAL_ID_PASSWORD_RESET=  # optional; defaults to password-reset template cmo1t3r8003870izrgv2vae6a
# Create transactional templates with data variables: firstName, confirmationLink (sign-up + password reset)
# (confirmationLink = full Supabase verify URL). @see https://loops.so/docs/api-reference/send-transactional-email
# Supabase must allow your app callback in Authentication → URL Configuration → Redirect URLs, e.g.
# https://YOUR_DOMAIN/auth/callback?next=/screener (GET /api/auth/signup-with-loops reports loopsConfigured + adminConfigured)

# Logo.dev — required for correct stock/crypto logos via `/api/media/logo` (server never exposes token to browser).
# Get keys at https://www.logo.dev/
LOGO_DEV_PUBLISHABLE_KEY=
# Optional: same publishable key, used only as fallback in server logo proxy
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# Optional: cap Logo.dev upstream fetches per server instance (default 500000 / 30d)
# FINSEPA_LOGO_DEV_MAX_REQUESTS_PER_30D=500000

# SEC EDGAR — identify your app when fetching public Form 13F data (Superinvestors). Recommended in production.
# Example: Finsepa/1.0 (contact@yourdomain.com)
# @see https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=
