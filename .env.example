# Copy to `.env.local` and fill in. For production, set the same keys in Vercel:
# Project → Settings → Environment Variables (Production + Preview), then redeploy.

# Supabase — required for auth and any client using getSupabaseBrowserClient().
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public origin for auth redirects (sign-up confirmation link, OAuth callback). No trailing slash.
# Production (Vercel): https://app.finsepa.com — ensures Supabase redirect_to is https + /auth/callback, not a bad browser origin.
# Local: omit to use http://localhost:3000 from the browser, or set NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_APP_ORIGIN=https://app.finsepa.com
#
# `npm run dev` / `dev:clean` / `dev:webpack` pin PORT=3000 and `-p 3000` so the app stays on http://localhost:3000.
# If something else is bound to 3000, run `npm run dev:free-port` (macOS/Linux) then `npm run dev` again.

# Supabase service role — server-only (watchlist counts, `/api/auth/signup-with-loops` admin generateLink). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# Sign-up abuse protection (bot floods hit `/api/auth/signup-with-loops` + direct Supabase Auth).
# EMERGENCY: set both in Vercel Production, redeploy, then run `npm run db:migrate` for billing-on-confirm trigger.
# AUTH_SIGNUP_DISABLED=1
# NEXT_PUBLIC_AUTH_SIGNUP_DISABLED=1
# Cloudflare Turnstile (free): https://dash.cloudflare.com → Turnstile → add site → copy keys
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Also enable Turnstile under Supabase Dashboard → Authentication → Bot and Abuse Protection (blocks direct signUp).
# AUTH_SIGNUP_LOOPS_API_ONLY=1
# NEXT_PUBLIC_AUTH_SIGNUP_LOOPS_API_ONLY=1
# Purge spam users after attack: node --env-file=.env.local scripts/purge-spam-auth-users.mjs [--delete]

# Auth emails (sign-up confirmation, password reset): use Supabase Dashboard → Authentication → SMTP
# with Loops as the provider (host smtp.loops.so, user "loops", password = Loops API key). See:
# https://loops.so/docs/smtp — credentials live in Supabase, not in these Next.js env vars.
# Enable "Confirm email" under Authentication → Providers → Email so sign-ups must verify.
#
# If Supabase still returns "Error sending confirmation email" or email rate limits, Finsepa falls back to Loops HTTP API (needs service role + LOOPS_API_KEY):
# LOOPS_API_KEY=                    # required for fallback — from https://app.loops.so → Settings → API
# LOOPS_TRANSACTIONAL_ID_SIGNUP=  # optional; defaults to Finsepa sign-up template cm54x9u6103qnqa68w7cg1ls7
# LOOPS_TRANSACTIONAL_ID_PASSWORD_RESET=  # optional; defaults to password-reset template cmo1t3r8003870izrgv2vae6a
# LOOPS_TRANSACTIONAL_ID_PRO_ACTIVATED=   # optional; defaults to “Finsepa Pro is now active” template cm0o8ezzr0qrb0i2mhrw29zlx (Stripe invoice.paid subscription_create)
# LOOPS_TRANSACTIONAL_ID_PRO_RENEWED=     # optional; defaults to “Finsepa Pro has been renewed” template cm0o8r6n40k7y0izkctvh3nvq (Stripe invoice.paid subscription_cycle)
# Create transactional templates with data variables: firstName, confirmationLink (sign-up + password reset)
# (confirmationLink = full Supabase verify URL). @see https://loops.so/docs/api-reference/send-transactional-email
# Supabase must allow your app callback in Authentication → URL Configuration → Redirect URLs, e.g.
# https://YOUR_DOMAIN/auth/callback?next=/screener (GET /api/auth/signup-with-loops reports loopsConfigured + adminConfigured)

# Logo.dev — required for correct stock/crypto logos via `/api/media/logo` (server never exposes token to browser).
# Get keys at https://www.logo.dev/
LOGO_DEV_PUBLISHABLE_KEY=
# Optional: same publishable key, used only as fallback in server logo proxy
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# Optional: cap Logo.dev upstream fetches per server instance (default 500000 / 30d)
# FINSEPA_LOGO_DEV_MAX_REQUESTS_PER_30D=500000

# SEC EDGAR — identify your app when fetching public Form 13F data (Superinvestors) and when resolving
# earnings “Slides / Filings” links (data.sec.gov submissions + filing indexes). Recommended in production.
# Example: Finsepa/1.0 (contact@yourdomain.com)
# @see https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=

# Stripe billing (migration-safe setup)
# Primary account API key (used when STRIPE_ACCOUNTS_JSON is not provided)
STRIPE_SECRET_KEY=
# Stripe webhook signing secret for /api/stripe/webhook?account=primary
STRIPE_WEBHOOK_SECRET=
# Payment Links used by Upgrade modal checkout launcher (fallback when price IDs below are unset)
STRIPE_PAYMENT_LINK_MONTHLY=
STRIPE_PAYMENT_LINK_ANNUAL=
# Optional: Stripe Price IDs for Pro monthly / annual recurring prices. When both are set for the
# active account, checkout uses Stripe Checkout instead of Payment Links so the same `customer`
# is reused and Stripe does not create duplicate customers for one email on repeat purchases.
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_ANNUAL=price_...
# Required for backfill script that maps Stripe customers -> app users
# (must match account emails in Stripe)
# DATABASE_URL=postgresql://...
#
# If `db.<ref>.supabase.co` times out (IPv6-only), use Session pooler (IPv4). In Dashboard click **Connect**
# → **Session pooler** and paste the full URI (host may be `aws-1-...` not `aws-0-...`):
# SUPABASE_POOLER_URL=postgresql://postgres.<ref>:<password>@aws-?.<region>.pooler.supabase.com:5432/postgres
# Or build it: SUPABASE_POOLER_REGION + SUPABASE_POOLER_AWS_INDEX (0|1) + SUPABASE_DB_PASSWORD
# Optional account key label (default: "primary")
# STRIPE_PRIMARY_ACCOUNT_KEY=primary
#
# Optional multi-account configuration (JSON array). Use this to run primary + legacy Stripe accounts safely.
# Example:
# STRIPE_ACCOUNTS_JSON=[{"key":"primary","secretKey":"sk_live_xxx","webhookSecret":"whsec_xxx","monthlyPaymentLink":"https://buy.stripe.com/..","annualPaymentLink":"https://buy.stripe.com/..","monthlyPriceId":"price_..","annualPriceId":"price_..","portalReturnUrl":"https://app.finsepa.com/account?tab=billing"},{"key":"legacy","secretKey":"sk_live_old","webhookSecret":"whsec_old","portalReturnUrl":"https://app.finsepa.com/account?tab=billing"}]
