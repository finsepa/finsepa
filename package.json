{
  "name": "finsepa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3000 next dev -p 3000",
    "dev:clean": "rm -rf .next && PORT=3000 next dev -p 3000",
    "dev:free-port": "(lsof -ti tcp:3000 | xargs kill -9) 2>/dev/null || true",
    "dev:webpack": "PORT=3000 next dev --webpack -p 3000",
    "build": "next build",
    "start": "PORT=3000 next start -p 3000",
    "db:migrate": "node --env-file=.env.local scripts/apply-supabase-migrations.mjs",
    "billing:backfill": "node --env-file=.env.local scripts/backfill-billing-from-stripe.mjs",
    "loops:test-pro-emails": "node --env-file=.env.local scripts/test-loops-pro-emails.mjs",
    "loops:diagnose": "node --env-file=.env.local scripts/diagnose-loops-transactional.mjs",
    "eodhd:estimate": "node scripts/eodhd-load-estimate.mjs",
    "eodhd:probe": "node scripts/eodhd-traffic-probe.mjs",
    "lint": "eslint",
    "commit": "sh -c 'git add -A && git commit -m \"$1\"' --",
    "checkpoint": "sh -c 'git add -A && git commit -m \"checkpoint: $(date +%Y-%m-%d_%H-%M-%S)\"'"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.105.1",
    "@untitledui-pro/icons": "^0.0.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "date-fns": "^4.1.0",
    "lightweight-charts": "^5.1.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
